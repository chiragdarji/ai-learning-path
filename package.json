{
  "name": "ai-learning-path",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "tsx scripts/validate-content.ts && tsx scripts/generate-sitemap.ts && tsx scripts/generate-curriculum-api.ts",
    "build": "tsc -b && vite build && tsx scripts/prerender-routes.ts",
    "build:app": "tsc -b && vite build",
    "build:vercel": "npm run prebuild && tsc -b && vite build",
    "prerender": "tsx scripts/prerender-routes.ts",
    "lint": "oxlint",
    "preview": "vite preview",
    "validate:content": "tsx scripts/validate-content.ts",
    "check:links": "tsx scripts/check-links.ts",
    "content:extract": "tsx scripts/extract-content.ts",
    "migrate:supabase": "tsx scripts/run-supabase-migration.ts && tsx scripts/sync-phase-resources.ts",
    "sync:phase-resources": "tsx scripts/sync-phase-resources.ts",
    "digest:generate": "tsx scripts/generate-weekly-digest.ts",
    "sync:news": "tsx scripts/sync-news-highlights.ts",
    "merge:news": "tsx scripts/merge-news-highlights.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-tabs": "^1.1.15",
    "@sentry/react": "^10.62.0",
    "@supabase/supabase-js": "^2.108.2",
    "fuse.js": "^7.4.2",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
