# Client (browser) — used by Vite build
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only — do NOT prefix with VITE_; not bundled into the app
SUPABASE_SECRET_KEY=your-secret-key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# Migrations only — Database password from Supabase Dashboard → Settings → Database
SUPABASE_DB_PASSWORD=your-database-password

# Optional: full connection string instead of SUPABASE_DB_PASSWORD
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Analytics & monitoring (optional)
VITE_PLAUSIBLE_DOMAIN=vidyanix.ai
VITE_SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project

# Admin access for /admin (comma-separated emails, optional)
VITE_ADMIN_EMAILS=you@company.com
